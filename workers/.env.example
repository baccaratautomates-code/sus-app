# Redis connection — must match apps/api/.env so the API and workers share a queue.
REDIS_URL=redis://localhost:6379

# BullMQ queue name — must match apps/api/.env.
WORKER_QUEUE_NAME=scraper-queue

# Scamadviser API — used by the scamadviser scraper.
# https://api.scamadviser.com — get an API key from your Scamadviser account.
SCAMADVISER_API_KEY=

# SerpAPI — used by the price-sanity scraper (Google Shopping).
# https://serpapi.com
SERPAPI_KEY=

# NewsAPI — used by the news scraper.
# https://newsapi.org
NEWS_API_KEY=

# Postgres connection — used by the internal-scam-db scraper.
# Read by Bun.sql automatically. Leave unset to skip the internal-scam-db lookup.
DATABASE_URL=
