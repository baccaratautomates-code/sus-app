# Expo public env vars — prefix with EXPO_PUBLIC_ so they are bundled into the JS bundle.
# Copy this file to .env and fill in your values.

# API base URL for the Sus backend.
# Dev (web):    http://localhost:3000
# Dev (device): http://<your-LAN-IP>:3000
# Staging/prod: https://api.sus.app (or whatever your deployment URL is)
EXPO_PUBLIC_API_BASE=http://localhost:3000

# RevenueCat API keys — get these from app.revenuecat.com → your project → API Keys.
# Android key starts with "goog_", iOS key starts with "appl_".
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
