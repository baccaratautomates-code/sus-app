{
  "expo": {
    "name": "Sus",
    "slug": "sus",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.disruptorsmedia.sus"
    },
    "android": {
      "package": "com.disruptorsmedia.sus"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "Check on Sus",
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1
          },
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      "expo-font"
    ],
    "scheme": "sus",
    "web": {
      "bundler": "metro"
    }
  }
}
