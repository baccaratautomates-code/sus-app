# Redis connection — used for both the 7-day verdict cache and the BullMQ scraper queue.
REDIS_URL=redis://localhost:6379

# Groq API key — synthesis layer (llama-3.1-8b-instant).
GROQ_API_KEY=gsk_...

# Postgres connection — users + scans persistence (PRD §8.1).
# Local: postgres://user:pass@localhost:5432/sus
# Neon:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/sus?sslmode=require
DATABASE_URL=postgresql://...

# BullMQ queue name — scraper workers consume from this queue.
WORKER_QUEUE_NAME=scraper-queue

# RevenueCat webhook shared secret. Set this in:
#   1. RevenueCat dashboard → Integrations → Webhooks → "Authorization header value"
#      (this field becomes the LITERAL Authorization header value — do NOT prefix with "Bearer ")
#   2. Here, exactly the same string
# Generate with: openssl rand -hex 32   (or any long random string)
# When unset, /webhooks/revenuecat returns 503 — safe default for local dev.
REVENUECAT_WEBHOOK_SECRET=
