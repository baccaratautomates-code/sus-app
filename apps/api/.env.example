# Redis connection — used for both the 7-day verdict cache and the BullMQ scraper queue.
REDIS_URL=redis://localhost:6379

# Groq API key — synthesis layer (llama-3.1-8b-instant).
GROQ_API_KEY=gsk_...

# Postgres connection — users + scans persistence (PRD §8.1).
# Local: postgres://user:pass@localhost:5432/sus
# Neon:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/sus?sslmode=require
DATABASE_URL=postgresql://...

# BullMQ queue name — scraper workers consume from this queue.
WORKER_QUEUE_NAME=scraper-queue
